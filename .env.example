# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_LV1=price_...
STRIPE_PRICE_LV2=price_...
STRIPE_PRICE_LV3=price_...

# WhatsApp Business Number (format: country code + number, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=393XXXXXXXXX

# Zoho Cliq Webhook URL (for lead notifications)
ZOHO_CLIQ_WEBHOOK_URL=https://cliq.zoho.com/api/...

# Analytics (optional)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_ID=

# A/B Testing
# Options: 'A' | 'B' (controls hero headline variant)
NEXT_PUBLIC_HERO_VARIANT=A

# Base URL (auto-detected in most cases)
NEXT_PUBLIC_BASE_URL=https://your-domain.com
